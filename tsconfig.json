{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "react-native": ["./node_modules/react-native-web"]
    }
  },
  "include": ["src/**/*"]
}
